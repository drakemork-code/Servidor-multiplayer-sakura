; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Sakura Chronicles"
config/description="Sakura Chronicles — MMORPG Pixel Art — Godot 4.6"
run/main_scene="res://scenes/server_main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0, 0, 0, 1)
config/icon="res://icon.png"
boot_splash/show_image=false

[autoload]

NetworkManager="*res://systems/network_manager.gd"
PermissionManager="*res://systems/permission_manager.gd"
GameManager="*res://systems/game_manager.gd"
PlayerData="*res://systems/player_data.gd"
InventoryManager="*res://systems/inventory_manager.gd"
EnemyManager="*res://systems/enemy_manager.gd"
CraftManager="*res://systems/craft_manager.gd"
AudioManager="*res://systems/audio_manager.gd"
AuctionManager="*res://systems/auction_manager.gd"
BankManager="*res://systems/bank_manager.gd"
ToolManager="*res://systems/tool_manager.gd"
QualitySystem="*res://systems/quality_system.gd"
ArmorStatsSystem="*res://systems/armor_stats_system.gd"
HudConfig="*res://systems/hud_config.gd"
WeaponSkillSystem="*res://systems/weapon_skill_system.gd"
PartyManager="*res://systems/party_manager.gd"
ChatManager="*res://systems/chat_manager.gd"
GuildManager="*res://systems/guild_manager.gd"
DailyLoopManager="*res://systems/daily_loop_manager.gd"
AchievementManager="*res://systems/achievement_manager.gd"
BossNotifManager="*res://systems/boss_notification_manager.gd"
MinimapManager="*res://systems/minimap_manager.gd"
LoadingScreen="*res://systems/loading_screen.tscn"
ServerMain="*res://server_main.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=false
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="landscape"

[gdscript]

warnings/inferred_declaration=0
warnings/untyped_declaration=0
warnings/unsafe_cast=0
warnings/unsafe_call_argument=0
warnings/unsafe_property_access=0
warnings/unsafe_method_access=0
warnings/return_value_discarded=0

